<?xml version="1.0" encoding="UTF-8"?>
<svg id="logo" width="800" height="800" viewBox="0 0 800 800" xmlns="http://www.w3.org/2000/svg">
<defs><style>
@font-face { font-family:'Cinzel'; src:url(data:font/woff2;base64,) format('woff2'); font-weight:600; }
@font-face { font-family:'Cinzel'; src:url(data:font/woff2;base64,) format('woff2'); font-weight:500; }
@font-face { font-family:'Cinzel'; src:url(data:font/woff2;base64,) format('woff2'); font-weight:400; }
@font-face { font-family:'Cormorant Garamond'; src:url(data:font/woff2;base64,) format('woff2'); font-weight:400; }
@font-face { font-family:'Cormorant Garamond'; src:url(data:font/woff2;base64,) format('woff2'); font-weight:500; font-style:italic; }
* { margin:0; padding:0; }
html,body { background:transparent; }
text{font-family:'Cinzel',serif;}
</style></defs>
  <defs>
    <radialGradient id="bgGrad" cx="42%" cy="34%" r="75%">
      <stop offset="0%" stop-color="#faf3e6"/>
      <stop offset="55%" stop-color="#f2e6d1"/>
      <stop offset="100%" stop-color="#e8d8b8"/>
    </radialGradient>
    <linearGradient id="pillarGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#233457"/>
      <stop offset="100%" stop-color="#111c33"/>
    </linearGradient>
    <linearGradient id="lanternGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" stop-color="#d6572a"/>
      <stop offset="100%" stop-color="#a83a1a"/>
    </linearGradient>
    <mask id="moonCut">
      <rect x="0" y="0" width="800" height="800" fill="white"/>
      <circle cx="572" cy="172" r="35" fill="black"/>
    </mask>
  </defs>

  <!-- outer crest rings -->
  <circle cx="400" cy="400" r="392" fill="none" stroke="#c9a227" stroke-width="1.5" opacity="0.9"/>
  <circle cx="400" cy="400" r="378" fill="none" stroke="#c9a227" stroke-width="1"/>
  <!-- compass dots -->
  <circle cx="400" cy="6"   r="3.2" fill="#c9a227"/>
  <circle cx="400" cy="794" r="3.2" fill="#c9a227"/>
  <circle cx="6"   cy="400" r="3.2" fill="#c9a227"/>
  <circle cx="794" cy="400" r="3.2" fill="#c9a227"/>

  <!-- background disc -->
  <circle cx="400" cy="400" r="364" fill="url(#bgGrad)"/>
  <circle cx="400" cy="400" r="364" fill="none" stroke="#c9a227" stroke-width="2.5"/>

  <!-- stars -->
  <g fill="#c9a227">
    <circle cx="228" cy="160" r="3"/>
    <circle cx="258" cy="128" r="2"/>
    <circle cx="196" cy="196" r="2.2"/>
    <circle cx="270" cy="205" r="1.8"/>
    <circle cx="480" cy="150" r="2"/>
    <circle cx="455" cy="230" r="1.8"/>
  </g>

  <!-- crescent moon -->
  <circle cx="555" cy="185" r="40" fill="#c9a227" mask="url(#moonCut)"/>

  <!-- torii gate -->
  <g>
    <!-- footings -->
    <rect x="322" y="548" width="46" height="14" rx="2" fill="#111c33"/>
    <rect x="432" y="548" width="46" height="14" rx="2" fill="#111c33"/>

    <!-- pillars -->
    <rect x="336" y="300" width="22" height="252" fill="url(#pillarGrad)"/>
    <rect x="442" y="300" width="22" height="252" fill="url(#pillarGrad)"/>
    <!-- pillar vermillion inlay -->
    <rect x="345" y="300" width="4" height="252" fill="#c1440e" opacity="0.85"/>
    <rect x="451" y="300" width="4" height="252" fill="#c1440e" opacity="0.85"/>

    <!-- nuki lower tie beam -->
    <rect x="330" y="378" width="140" height="16" rx="2" fill="url(#pillarGrad)"/>

    <!-- gakuzuka central post -->
    <rect x="390" y="292" width="20" height="52" fill="url(#pillarGrad)"/>

    <!-- shimaki second beam -->
    <path d="M 300 288 L 500 288 L 494 302 L 306 302 Z" fill="url(#pillarGrad)"/>

    <!-- kasagi top curved beam -->
    <path d="M 284 268
             Q 400 244 516 268
             L 520 286
             Q 400 262 280 286 Z" fill="url(#pillarGrad)"/>
    <path d="M 284 268 Q 400 244 516 268 L 518 274 Q 400 251 282 274 Z" fill="#c1440e" opacity="0.85"/>

    <!-- hanging lantern -->
    <g>
      <rect x="393" y="394" width="14" height="10" fill="#c9a227"/>
      <path d="M 400 402
               C 372 402 366 424 366 438
               C 366 456 380 470 400 470
               C 420 470 434 456 434 438
               C 434 424 428 402 400 402 Z" fill="url(#lanternGrad)" stroke="#c9a227" stroke-width="2"/>
      <line x1="376" y1="418" x2="376" y2="456" stroke="#8f2c11" stroke-width="1" opacity="0.5"/>
      <line x1="388" y1="426" x2="388" y2="462" stroke="#8f2c11" stroke-width="1" opacity="0.5"/>
      <line x1="412" y1="426" x2="412" y2="462" stroke="#8f2c11" stroke-width="1" opacity="0.5"/>
      <line x1="424" y1="418" x2="424" y2="456" stroke="#8f2c11" stroke-width="1" opacity="0.5"/>
      <rect x="392" y="466" width="16" height="6" fill="#c9a227"/>
      <line x1="400" y1="472" x2="400" y2="486" stroke="#c9a227" stroke-width="2"/>
      <circle cx="400" cy="490" r="3.5" fill="#c9a227"/>
    </g>
  </g>

  <!-- divider -->
  <line x1="355" y1="600" x2="445" y2="600" stroke="#c9a227" stroke-width="1.5"/>
  <path d="M 400 594 l 6 6 l -6 6 l -6 -6 Z" fill="#c9a227"/>

  <!-- wordmark -->
  <text x="400" y="648" text-anchor="middle" font-family="Cinzel" font-weight="600" font-size="58" letter-spacing="14" fill="#16233f">HTE</text>

  <!-- tagline -->
  <text x="400" y="682" text-anchor="middle" font-family="Cormorant Garamond" font-style="italic" font-weight="500" font-size="18" letter-spacing="3.5" fill="#8a6d1f">Hidden Tokyo Experiences</text>

</svg>
